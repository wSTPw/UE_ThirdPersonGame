root = true

# General
[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true

# C/C++/Headers (Unreal Engine conventions)
[*.{cpp,h,hpp,inl,generated.h}]
indent_style = tab
tab_width = 4
charset = utf-8
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = false

# Editor config for Visual Studio project and solution files
[*.{sln,vcxproj,vcxproj.filters}]
charset = utf-8
end_of_line = crlf

# Text files
[*.{txt,md}]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = false